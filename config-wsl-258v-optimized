# WSL2 Kernel Config for Intel Core Ultra 258V
# Optimized for Lunar Lake (no AVX-512, AVX2 only)
# Date: 2026-03-02

# 基础 WSL2 配置
CONFIG_WSL=y
CONFIG_DXGKRNL=y
CONFIG_HYPERV=y
CONFIG_HYPERV_STORAGE=y
CONFIG_HYPERV_NET=y
CONFIG_HYPERV_UTILS=y
CONFIG_HYPERV_BALLOON=y

# CPU 优化
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
# CONFIG_CC_OPTIMIZE_FOR_SIZE is not set
CONFIG_MCORE2=y
CONFIG_MPENTIUM4=y
CONFIG_X86_64=y
CONFIG_X86_64_V3=y

# 禁用 5 级页表 (258V 不支持)
CONFIG_X86_5LEVEL=n

# 禁用 AVX-512 (258V 不支持)
CONFIG_AS_AVX512=n
CONFIG_X86_AVX512=n
# CONFIG_AVX512F is not set
# CONFIG_AVX512_VBMI2 is not set
# CONFIG_AVX512_VL is not set
# CONFIG_AVX512_VNNI is not set
# CONFIG_AVX512_BF16 is not set
# CONFIG_AVX512_FP16 is not set

# LTO 优化 (Thin LTO)
CONFIG_LTO_CLANG=y
CONFIG_LTO_CLANG_THIN=y
CONFIG_LTO=n

# 调度器优化
CONFIG_PREEMPT_VOLUNTARY=y
# CONFIG_PREEMPT_NONE is not set
# CONFIG_PREEMPT is not set

# 定时器频率
CONFIG_HZ_1000=y
# CONFIG_HZ_500 is not set
# CONFIG_HZ_300 is not set
# CONFIG_HZ_250 is not set
# CONFIG_HZ_100 is not set
CONFIG_HZ=1000

# 内存优化
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_KSM=y

# I/O 优化
CONFIG_BFQ_GROUP_IOSCHED=y
CONFIG_BFQ_IOSCHED=y
CONFIG_MQ_IOSCHED_DEADLINE=y

# 精简驱动 - 只保留必要的
# 移除不用的硬件支持
CONFIG_EISA=n
CONFIG_DMADEV=n

# 保留 WSL2 必需的
CONFIG_DXGKRNL=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_LOGO=y

# 网络优化
CONFIG_NET=y
CONFIG_INET=y
CONFIG_TCP_CONG_CUBIC=y
CONFIG_DEFAULT_TCP_CONG="cubic"

# 文件系统优化
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_BTRFS_FS=n  # 禁用 BTRFS (不需要)
CONFIG_XFS_FS=n    # 禁用 XFS (不需要)

# 调试选项 (生产环境禁用)
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_DEBUG_INFO is not set
